<?xml version="1.0" encoding="utf-8"?>
<!-- Debug-only: allow cleartext HTTP so the app can reach the local dev
     backend (host LAN IP / emulator loopback). Release builds do not include
     this file and remain HTTPS-only. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
